{
  "realm": "myrealm",
  "enabled": true,
  "displayName": "My Realm",
  "accountTheme": "keycloak",
  "loginTheme": "keycloak",
  "adminTheme": "keycloak",
  "emailTheme": "keycloak",
  "defaultSignatureAlgorithm": "RS256",
  "revokeRefreshToken": false,
  "refreshTokenMaxReuse": 0,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespan": 5184000,
  "clientSessionIdleTimeout": 0,
  "clientSessionMaxLifespan": 0,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "defaultRoles": ["offline_access", "uma_authorization"],
  "sslRequired": "external",
  "passwordPolicy": "length(8) and specialChars(1) and upperCase(1) and digits(1) and notUsername(undefined)",
  "userFederationProviders": [
    {
      "id": "ldap1-provider",
      "displayName": "LDAP 1",
      "providerName": "ldap",
      "config": {
        "priority": "0",
        "connectionUrl": "ldap://ldap1:389",
        "editMode": "READ_ONLY",
        "usersDn": "ou=users,dc=org1,dc=local",
        "bindDn": "cn=admin,dc=org1,dc=local",
        "bindCredential": "admin",
        "usernameLDAPAttribute": "uid",
        "rdnLDAPAttribute": "cn",
        "uuidLDAPAttribute": "entryUUID",
        "userObjectClasses": "inetOrgPerson"
      }
    },
    {
      "id": "ldap2-provider",
      "displayName": "LDAP 2",
      "providerName": "ldap",
      "config": {
        "priority": "1",
        "connectionUrl": "ldap://ldap2:389",
        "editMode": "READ_ONLY",
        "usersDn": "ou=users,dc=org2,dc=local",
        "bindDn": "cn=admin,dc=org2,dc=local",
        "bindCredential": "admin",
        "usernameLDAPAttribute": "uid",
        "rdnLDAPAttribute": "cn",
        "uuidLDAPAttribute": "entryUUID",
        "userObjectClasses": "inetOrgPerson"
      }
    }
  ],
  "clients": [
    {
      "clientId": "my-app",
      "name": "My Application",
      "description": "OAuth2/OIDC client for Authorization Code Flow",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "my-app-secret-change-this",
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:3000/callback",
        "http://localhost:3000/*"
      ],
      "webOrigins": ["http://localhost:3000"],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "consentRequired": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "given name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "firstName",
            "id.token.claim": "true",
            "access.token.claim": "false",
            "claim.name": "given_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "family name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "lastName",
            "id.token.claim": "true",
            "access.token.claim": "false",
            "claim.name": "family_name",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ]
}
