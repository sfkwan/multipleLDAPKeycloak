{
  "realm": "myrealm",
  "enabled": true,
  "displayName": "My Realm",
  "accountTheme": "keycloak",
  "loginTheme": "keycloak",
  "adminTheme": "keycloak",
  "emailTheme": "keycloak",
  "defaultSignatureAlgorithm": "RS256",
  "revokeRefreshToken": false,
  "refreshTokenMaxReuse": 0,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespan": 5184000,
  "clientSessionIdleTimeout": 0,
  "clientSessionMaxLifespan": 0,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "defaultRoles": ["offline_access", "uma_authorization"],
  "sslRequired": "external",
  "passwordPolicy": "length(8) and specialChars(1) and upperCase(1) and digits(1) and notUsername(undefined)",
  "userFederationProviders": [
    {
      "id": "ldap-hk-provider",
      "displayName": "HK",
      "providerName": "ldap",
      "config": {
        "priority": "0",
        "connectionUrl": "ldap://ldap-hk:389",
        "editMode": "READ_ONLY",
        "usersDn": "ou=users,dc=org1,dc=local",
        "bindDn": "cn=admin,dc=org1,dc=local",
        "bindCredential": "admin",
        "usernameLDAPAttribute": "uid",
        "rdnLDAPAttribute": "cn",
        "uuidLDAPAttribute": "entryUUID",
        "userObjectClasses": "inetOrgPerson"
      }
    },
    {
      "id": "ldap-china-provider",
      "displayName": "China",
      "providerName": "ldap",
      "config": {
        "priority": "1",
        "connectionUrl": "ldap://ldap-china:389",
        "editMode": "READ_ONLY",
        "usersDn": "ou=users,dc=org2,dc=local",
        "bindDn": "cn=admin,dc=org2,dc=local",
        "bindCredential": "admin",
        "usernameLDAPAttribute": "uid",
        "rdnLDAPAttribute": "cn",
        "uuidLDAPAttribute": "entryUUID",
        "userObjectClasses": "inetOrgPerson"
      }
    }
  ],
  "userFederationMappers": [
    {
      "id": "ldap-hk-username-mapper",
      "name": "username",
      "federationProviderDisplayName": "HK",
      "federationMapperType": "user-attribute-ldap-mapper",
      "config": {
        "ldap.attribute": "uid",
        "is.mandatory.in.ldap": "true",
        "always.read.value.from.ldap": "true",
        "user.model.attribute": "username",
        "read.only": "true"
      }
    },
    {
      "id": "ldap-hk-firstname-mapper",
      "name": "first name",
      "federationProviderDisplayName": "HK",
      "federationMapperType": "user-attribute-ldap-mapper",
      "config": {
        "ldap.attribute": "givenName",
        "is.mandatory.in.ldap": "true",
        "always.read.value.from.ldap": "true",
        "user.model.attribute": "firstName",
        "read.only": "true"
      }
    },
    {
      "id": "ldap-hk-lastname-mapper",
      "name": "last name",
      "federationProviderDisplayName": "HK",
      "federationMapperType": "user-attribute-ldap-mapper",
      "config": {
        "ldap.attribute": "sn",
        "is.mandatory.in.ldap": "true",
        "always.read.value.from.ldap": "true",
        "user.model.attribute": "lastName",
        "read.only": "true"
      }
    },
    {
      "id": "ldap-hk-email-mapper",
      "name": "email",
      "federationProviderDisplayName": "HK",
      "federationMapperType": "user-attribute-ldap-mapper",
      "config": {
        "ldap.attribute": "mail",
        "is.mandatory.in.ldap": "false",
        "always.read.value.from.ldap": "true",
        "user.model.attribute": "email",
        "read.only": "true"
      }
    },
    {
      "id": "ldap-hk-mobile-mapper",
      "name": "mobile",
      "federationProviderDisplayName": "HK",
      "federationMapperType": "user-attribute-ldap-mapper",
      "config": {
        "ldap.attribute": "mobile",
        "is.mandatory.in.ldap": "false",
        "always.read.value.from.ldap": "true",
        "user.model.attribute": "phoneNumber",
        "read.only": "true"
      }
    },
    {
      "id": "ldap-hk-street-mapper",
      "name": "street",
      "federationProviderDisplayName": "HK",
      "federationMapperType": "user-attribute-ldap-mapper",
      "config": {
        "ldap.attribute": "street",
        "is.mandatory.in.ldap": "false",
        "always.read.value.from.ldap": "true",
